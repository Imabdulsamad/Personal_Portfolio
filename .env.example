CONTACT_FROM_EMAIL=onboarding@resend.dev

# Where contact-form submissions are delivered.
CONTACT_TO_EMAIL=fahad@transcargomovers.com

# Public site URL — used for canonical links, sitemap & robots.
NEXT_PUBLIC_SITE_URL=https://abdulsamad.dev
