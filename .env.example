# Resend — https://resend.com/api-keys
# Required for the contact form Server Action to send email.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# The verified "from" address on your Resend account (e.g. noreply@yourdomain.com).
